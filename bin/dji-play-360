#!/bin/bash

# dji-play-360 - Launches mpv to play DJI Osmo 360 (.osv) videos in real-time

PRESET="default"
HW_ACCEL_OVERRIDE=""
FOV_VAL="3.35"
BLEND_VAL="0.04"
SENS_VAL="0.0035"
LAUNCH_GUI=false
ARGS=()

# Analyze all passed arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fast)
            PRESET="fast"
            shift
            ;;
        --fastest)
            PRESET="fastest"
            shift
            ;;
        --hw-accel)
            HW_ACCEL_OVERRIDE="$2"
            shift 2
            ;;
        --fov)
            FOV_VAL="$2"
            shift 2
            ;;
        --blend)
            BLEND_VAL="$2"
            shift 2
            ;;
        --sens)
            SENS_VAL="$2"
            shift 2
            ;;
        --gui)
            LAUNCH_GUI=true
            shift
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# If GUI is requested or no arguments are provided and we are in a graphical session, start the GUI launcher
if [ "$LAUNCH_GUI" = true ] || { [ ${#ARGS[@]} -eq 0 ] && { [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; }; }; then
    SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
    if [ -f "$SCRIPT_DIR/dji-play-360-gui" ]; then
        exec "$SCRIPT_DIR/dji-play-360-gui" "${ARGS[@]}"
    elif command -v dji-play-360-gui &>/dev/null; then
        exec dji-play-360-gui "${ARGS[@]}"
    else
        echo "Error: dji-play-360-gui not found."
        exit 1
    fi
fi

# If no arguments and no graphical display (pure CLI mode without files)
if [ ${#ARGS[@]} -eq 0 ]; then
    echo "Usage: dji-play-360 <video_dji.osv> [options]"
    echo ""
    echo "General options:"
    echo "  --gui       Launch the Graphical User Interface (GUI)"
    echo "  --hw-accel  Force hardware acceleration (nvidia | vaapi | cpu)"
    echo ""
    echo "Performance options:"
    echo "  --fast      Downscale to 1.4K per lens and disable loop filter."
    echo "  --fastest   Downscale to 1K per lens and apply maximum decoding optimizations."
    echo ""
    echo "Calibration options:"
    echo "  --fov       Initial field of view in radians (default: 3.35)"
    echo "  --blend     Lens seam blend range [0.0 - 0.25] (default: 0.04)"
    echo "  --sens      Mouse rotation drag sensitivity (default: 0.0035)"
    exit 1
fi

# Configure filters and parameters based on the preset
# Get the absolute path of the video file and remove it from mpv arguments
VIDEO_PATH=""
MPV_ARGS=()
for arg in "${ARGS[@]}"; do
    if [[ ! "$arg" =~ ^- ]] && [ -z "$VIDEO_PATH" ] && [ -f "$arg" ]; then
        VIDEO_PATH=$(readlink -f "$arg")
    else
        MPV_ARGS+=("$arg")
    fi
done

if [ -z "$VIDEO_PATH" ]; then
    echo "Error: specify a valid video file."
    exit 1
fi

# Determine the directory for the temporary file in ~/.cache/dji-play-360
CACHE_DIR="$HOME/.cache/dji-play-360"
mkdir -p "$CACHE_DIR"
TEMP_FILE="$CACHE_DIR/$(basename "${VIDEO_PATH%.*}")_$(date +%s)_$$.ts"

# Hardware acceleration auto-detection or override
HW_ACCEL="cpu"
if [ -n "$HW_ACCEL_OVERRIDE" ]; then
    HW_ACCEL="$HW_ACCEL_OVERRIDE"
    echo "Hardware acceleration forced by arguments: $HW_ACCEL"
else
    if command -v nvidia-smi &> /dev/null && nvidia-smi &> /dev/null; then
        HW_ACCEL="nvidia"
    elif [ -e /dev/dri/renderD128 ] && ffmpeg -encoders 2>/dev/null | grep -q hevc_vaapi; then
        HW_ACCEL="vaapi"
    fi
fi

if [ "$HW_ACCEL" = "nvidia" ]; then
    # NVIDIA CUDA Pipeline (100% in GPU VRAM)
    if [ "$PRESET" = "fast" ]; then
        echo "NVIDIA GPU detected. Starting in FAST mode (1.4K GPU scale & transcode)..."
        LAVFI_FILTER="[0:v:0]scale_cuda=w=1440:h=1440:format=nv12[v1_scaled]; [v1_scaled]pad_cuda=w=iw*2:h=ih:x=0:y=0[v1_padded]; [0:v:1]scale_cuda=w=1440:h=1440:format=nv12[v2_scaled]; [v1_padded][v2_scaled]overlay_cuda=x=1440:y=0[vo]"
    elif [ "$PRESET" = "fastest" ]; then
        echo "NVIDIA GPU detected. Starting in ULTRA FAST mode (1K GPU scale & transcode)..."
        LAVFI_FILTER="[0:v:0]scale_cuda=w=1024:h=1024:format=nv12[v1_scaled]; [v1_scaled]pad_cuda=w=iw*2:h=ih:x=0:y=0[v1_padded]; [0:v:1]scale_cuda=w=1024:h=1024:format=nv12[v2_scaled]; [v1_padded][v2_scaled]overlay_cuda=x=1024:y=0[vo]"
    else
        echo "NVIDIA GPU detected. Starting at native max quality (7.6K GPU transcode)..."
        LAVFI_FILTER="[0:v:0]scale_cuda=format=nv12[v1_scaled]; [v1_scaled]pad_cuda=w=iw*2:h=ih:x=0:y=0[v1_padded]; [0:v:1]scale_cuda=format=nv12[v2_scaled]; [v1_padded][v2_scaled]overlay_cuda=x=3840:y=0[vo]"
    fi
    
    FFMPEG_CMD=(
        ffmpeg -y -loglevel warning
        -hwaccel cuda -hwaccel_output_format cuda
        -i "$VIDEO_PATH"
        -filter_complex "$LAVFI_FILTER"
        -map "[vo]" -map 0:a?
        -c:v hevc_nvenc -preset p1 -rc constqp -qp 22
        -c:a copy
        -f mpegts "$TEMP_FILE"
    )
elif [ "$HW_ACCEL" = "vaapi" ]; then
    # AMD/Intel VAAPI Pipeline (uses accelerated decode, software hstack, hardware encode)
    if [ "$PRESET" = "fast" ]; then
        echo "AMD/Intel GPU (VAAPI) detected. Starting in FAST mode (1.4K CPU scale & hstack)..."
        LAVFI_FILTER="[0:v:0]scale=w=1440:h=1440[v1_scaled]; [0:v:1]scale=w=1440:h=1440[v2_scaled]; [v1_scaled][v2_scaled]hstack[vo]"
    elif [ "$PRESET" = "fastest" ]; then
        echo "AMD/Intel GPU (VAAPI) detected. Starting in ULTRA FAST mode (1K CPU scale & hstack)..."
        LAVFI_FILTER="[0:v:0]scale=w=1024:h=1024[v1_scaled]; [0:v:1]scale=w=1024:h=1024[v2_scaled]; [v1_scaled][v2_scaled]hstack[vo]"
    else
        echo "AMD/Intel GPU (VAAPI) detected. Starting at native max quality (7.6K hstack)..."
        LAVFI_FILTER="[0:v:0][0:v:1]hstack[vo]"
    fi

    FFMPEG_CMD=(
        ffmpeg -y -loglevel warning
        -hwaccel vaapi -hwaccel_device /dev/dri/renderD128
        -i "$VIDEO_PATH"
        -filter_complex "$LAVFI_FILTER"
        -map "[vo]" -map 0:a?
        -c:v hevc_vaapi -global_quality 22
        -c:a copy
        -f mpegts "$TEMP_FILE"
    )
else
    # CPU Pipeline (Software fallback)
    if [ "$PRESET" = "fast" ]; then
        echo "No GPU acceleration detected. Starting on CPU in FAST mode (1.4K software scale & hstack)..."
        LAVFI_FILTER="[0:v:0]scale=w=1440:h=1440[v1_scaled]; [0:v:1]scale=w=1440:h=1440[v2_scaled]; [v1_scaled][v2_scaled]hstack[vo]"
    elif [ "$PRESET" = "fastest" ]; then
        echo "No GPU acceleration detected. Starting on CPU in ULTRA FAST mode (1K software scale & hstack)..."
        LAVFI_FILTER="[0:v:0]scale=w=1024:h=1024[v1_scaled]; [0:v:1]scale=w=1024:h=1024[v2_scaled]; [v1_scaled][v2_scaled]hstack[vo]"
    else
        echo "No GPU acceleration detected. Starting on CPU at native max quality (7.6K hstack)..."
        LAVFI_FILTER="[0:v:0][0:v:1]hstack[vo]"
    fi

    FFMPEG_CMD=(
        ffmpeg -y -loglevel warning
        -i "$VIDEO_PATH"
        -filter_complex "$LAVFI_FILTER"
        -map "[vo]" -map 0:a?
        -c:v libx265 -preset ultrafast -crf 22
        -c:a copy
        -f mpegts "$TEMP_FILE"
    )
fi

# Manage script exit cleanup
cleanup() {
    if [ ! -z "$FFMPEG_PID" ]; then
        kill "$FFMPEG_PID" 2>/dev/null || true
        wait "$FFMPEG_PID" 2>/dev/null || true
    fi
    rm -f "$TEMP_FILE"
}
trap cleanup EXIT INT TERM

# Start ffmpeg transcoding in background writing to the temporary TS file
"${FFMPEG_CMD[@]}" &
FFMPEG_PID=$!

# Wait for the temp file to be created and contain data
for i in {1..50}; do
    if [ -s "$TEMP_FILE" ]; then
        break
    fi
    # If ffmpeg died, exit with error
    if ! kill -0 "$FFMPEG_PID" 2>/dev/null; then
        echo "Error: ffmpeg exited unexpectedly."
        exit 1
    fi
    sleep 0.1
done

# Start mpv playing the growing local temporary file
mpv --vo=gpu-next \
    --hwdec=auto \
    --force-seekable=yes \
    --cache=yes \
    --demuxer-max-bytes=1024MiB \
    --script-opts=mpv360-enabled=yes,mpv360-input_projection=1,mpv360-fisheye_fov=${FOV_VAL},mpv360-blend_range=${BLEND_VAL},mpv360-mouse_sensitivity=${SENS_VAL} \
    "$TEMP_FILE" \
    "${MPV_ARGS[@]}"
