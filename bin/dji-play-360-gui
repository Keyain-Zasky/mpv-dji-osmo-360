    def toggle_export_format(self):
        if self.format_var.get() == "2d":
            self.frame_2d_params.grid(row=4, column=0, columnspan=4, sticky="ew", pady=(5, 0))
        else:
            self.frame_2d_params.grid_forget()

    def browse_exp_in_file(self):
        fpath = filedialog.askopenfilename(
            title="Select DJI Osmo 360 Video",
            filetypes=[("DJI Osmo 360 Video", "*.osv *.OSV"), ("All Files", "*.*")]
        )
        if fpath:
            self.exp_in_entry.delete(0, tk.END)
            self.exp_in_entry.insert(0, fpath)
            
            outpath = self.exp_out_entry.get().strip()
            if not outpath:
                base, _ = os.path.splitext(fpath)
                self.exp_out_entry.insert(0, f"{base}_export.mp4")

    def browse_exp_out_file(self):
        fpath = filedialog.asksaveasfilename(
            title="Save Exported MP4 Video",
            defaultextension=".mp4",
            filetypes=[("MP4 Video", "*.mp4"), ("All Files", "*.*")]
        )
        if fpath:
            self.exp_out_entry.delete(0, tk.END)
            self.exp_out_entry.insert(0, fpath)

    # --- VIDEO EXPORT ENGINE ---
    def get_video_info(self, file_path):
        cmd = [
            "ffprobe", "-v", "error",
            "-show_entries", "format=duration",
            "-show_entries", "stream=width,height",
            "-of", "json",
            file_path
        ]
        try:
            res = subprocess.run(cmd, capture_output=True, text=True, check=True)
            data = json.loads(res.stdout)
            duration = float(data.get("format", {}).get("duration", 0))
            
            width, height = 0, 0
            for stream in data.get("streams", []):
                w = stream.get("width")
                h = stream.get("height")
                if w and h:
                    width = w
                    height = h
                    break
            return width, height, duration
        except Exception:
            return 0, 0, 0.0

    def start_export(self):
        in_file = self.exp_in_entry.get().strip()
        out_file = self.exp_out_entry.get().strip()

        if not in_file or not os.path.exists(in_file):
            messagebox.showerror("Input Error", "Please select a valid .OSV source file.")
            return
        if not out_file:
            messagebox.showerror("Output Error", "Please specify a valid MP4 target file path.")
            return

        # Save settings
        self.settings["enc_format"] = self.format_var.get()
        self.settings["encoder"] = self.codec_var.get()
        self.settings["hw_accel"] = self.exp_hw_var.get()
        self.settings["yaw"] = self.exp_yaw_scale.get()
        self.settings["pitch"] = self.exp_pitch_scale.get()
        self.settings["roll"] = self.exp_roll_scale.get()
        self.settings["fov_2d"] = self.exp_fov_scale.get()
        self.save_settings()

        self.lbl_progress_stats.config(text="Probing source metadata...", fg=FG_MAIN)
        width, height, duration = self.get_video_info(in_file)
        if duration <= 0:
            messagebox.showerror("Error", "Could not retrieve the duration of the source video.")
            self.lbl_progress_stats.config(text="Probing failed", fg=ALERT_RED)
            return

        hw = self.settings["hw_accel"]
        if hw == "auto":
            if subprocess.call("command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null", shell=True) == 0:
                hw = "nvidia"
            elif os.path.exists("/dev/dri/renderD128") and self.check_vaapi_support():
                hw = "vaapi"
            else:
                hw = "cpu"

        cmd = ["ffmpeg", "-y", "-loglevel", "warning"]

        if hw == "nvidia":
            cmd.extend(["-hwaccel", "cuda"])
        elif hw == "vaapi":
            cmd.extend(["-hwaccel", "vaapi", "-hwaccel_device", "/dev/dri/renderD128"])

        cmd.extend(["-i", in_file])

        # Stitch and project using custom FOV boundary
        fov_val = self.fov_scale.get()

        if self.settings["enc_format"] == "360":
            out_w = width if width > 0 else 3840
            out_h = int(out_w / 2)
            filter_str = f"[0:v:0][0:v:1]hstack=inputs=2[stacked]; [stacked]v360=input=dfisheye:output=e:ih_fov={fov_val}:iv_fov={fov_val}:w={out_w}:h={out_h}"
        else:
            yaw = self.settings["yaw"]
            pitch = self.settings["pitch"]
            roll = self.settings["roll"]
            fov_2d = self.settings["fov_2d"]
            v_fov = fov_2d * 0.5625  # 16:9 ratio
            filter_str = f"[0:v:0][0:v:1]hstack=inputs=2[stacked]; [stacked]v360=input=dfisheye:output=flat:ih_fov={fov_val}:iv_fov={fov_val}:yaw={yaw}:pitch={pitch}:roll={roll}:h_fov={fov_2d}:v_fov={v_fov}:w=1920:h=1080"

        cmd.extend(["-filter_complex", filter_str, "-map", "[vo]", "-map", "0:a?"])

        codec = self.settings["encoder"]
        if hw == "nvidia":
            enc = "h264_nvenc" if codec == "h264" else "hevc_nvenc"
            cmd.extend(["-c:v", enc, "-preset", "p5", "-cq", "22"])
        elif hw == "vaapi":
            enc = "h264_vaapi" if codec == "h264" else "hevc_vaapi"
            cmd.extend(["-c:v", enc, "-global_quality", "22"])
        else:
            enc = "libx264" if codec == "h264" else "libx265"
            cmd.extend(["-c:v", enc, "-preset", "medium", "-crf", "21"])

        cmd.extend(["-c:a", "copy", "-progress", "pipe:1", "-nostats", out_file])

        self.is_exporting = True
        self.btn_start_export.config_state("disabled")
        self.btn_cancel_export.default_bg = ALERT_RED
        self.btn_cancel_export.bg = ALERT_RED
        self.btn_cancel_export.config_state("normal")
        self.btn_clear_cache.config_state("disabled")
        self.tab_play_btn.config_state("disabled")

        self.prog_bar.set_progress(0.0)
        self.lbl_progress_stats.config(text="Initializing transcode pipeline...", fg=FG_MAIN)

        self.export_thread = threading.Thread(
            target=self.run_ffmpeg_export, 
            args=(cmd, duration), 
            daemon=True
        )
        self.export_thread.start()

    def check_vaapi_support(self):
        try:
            res = subprocess.run("ffmpeg -encoders 2>/dev/null | grep -q hevc_vaapi", shell=True)
            return res.returncode == 0
        except Exception:
            return False

    def run_ffmpeg_export(self, cmd, total_duration):
        try:
            self.export_proc = subprocess.Popen(
                cmd, 
                stdout=subprocess.PIPE, 
                stderr=subprocess.DEVNULL,
                universal_newlines=True
            )

            for line in self.export_proc.stdout:
                if "out_time_us" in line:
                    try:
                        time_us = int(line.split("=")[1].strip())
                        time_sec = time_us / 1000000.0
                        pct = time_sec / total_duration
                        self.export_queue.put(("progress", pct, time_sec, total_duration))
                    except Exception:
                        pass
                elif "speed" in line:
                    speed = line.split("=")[1].strip()
                    self.export_queue.put(("speed", speed))

            self.export_proc.wait()
            ret_code = self.export_proc.returncode
            if ret_code == 0:
                self.export_queue.put(("success", None))
            else:
                self.export_queue.put(("error", f"FFmpeg exited with exit code {ret_code}"))
        except Exception as e:
            self.export_queue.put(("error", str(e)))

    def check_queue_loop(self):
        try:
            speed_val = "1.0x"
            start_time = None
            
            while True:
                msg_type, *args = self.export_queue.get_nowait()
                
                if msg_type == "progress":
                    pct, time_sec, total_duration = args
                    self.prog_bar.set_progress(pct)
                    
                    if start_time is None:
                        start_time = time.time()
                    
                    elapsed = time.time() - start_time
                    if pct > 0.01:
                        eta_sec = (elapsed / pct) - elapsed
                        eta_str = time.strftime('%M:%S', time.gmtime(eta_sec))
                    else:
                        eta_str = "--:--"
                    
                    elapsed_str = time.strftime('%M:%S', time.gmtime(elapsed))
                    pct_str = f"{pct*100:.1f}%"
                    
                    self.lbl_progress_stats.config(
                        text=f"Progress: {pct_str} | Speed: {speed_val} | Elapsed: {elapsed_str} | ETA: {eta_str}",
                        fg=ACCENT
                    )

                elif msg_type == "speed":
                    speed_val = args[0]

                elif msg_type == "success":
                    self.is_exporting = False
                    self.prog_bar.set_progress(1.0)
                    self.lbl_progress_stats.config(text="Export completed successfully!", fg=SUCCESS_GREEN)
                    messagebox.showinfo("Success", "The video has been successfully exported to standard MP4!")
                    self.reset_export_ui()

                elif msg_type == "error":
                    self.is_exporting = False
                    err_msg = args[0]
                    self.lbl_progress_stats.config(text=f"Export error", fg=ALERT_RED)
                    messagebox.showerror("Export Failed", f"An error occurred during transcoding:\n{err_msg}")
                    self.reset_export_ui()
                    
        except queue.Empty:
            pass
        
        self.root.after(100, self.check_queue_loop)

    def cancel_export(self):
        if self.export_proc:
            if messagebox.askyesno("Cancel Export", "Are you sure you want to stop the export process?"):
                try:
                    self.export_proc.terminate()
                except Exception:
                    pass
                self.is_exporting = False
                self.lbl_progress_stats.config(text="Export canceled by user", fg=ALERT_RED)
                self.reset_export_ui()

    def reset_export_ui(self):
        self.btn_start_export.config_state("normal")
        self.btn_cancel_export.default_bg = "#202024"
        self.btn_cancel_export.bg = "#202024"
        self.btn_cancel_export.config_state("disabled")
        self.btn_clear_cache.config_state("normal")
        self.tab_play_btn.config_state("normal")
        self.export_proc = None
        self.export_thread = None

    # --- CLEAN CACHE UTILITY ---
    def clear_cache(self):
        files = [os.path.join(CACHE_DIR, f) for f in os.listdir(CACHE_DIR) if f.endswith(".ts")]
        if not files:
            messagebox.showinfo("Clean Cache", "No temporary cache files found.")
            return

        total_size = sum(os.path.getsize(f) for f in files)
        size_mb = total_size / (1024 * 1024)

        confirm = messagebox.askyesno(
            "Clean Cache", 
            f"Found {len(files)} temporary files ({size_mb:.1f} MB).\nDo you want to permanently delete them to free up disk space?"
        )
        if confirm:
            deleted_count = 0
            for f in files:
                try:
                    os.remove(f)
                    deleted_count += 1
                except Exception:
                    pass
            messagebox.showinfo("Clean Cache", f"Successfully deleted {deleted_count} of {len(files)} cache files!")

if __name__ == "__main__":
    sys.stdout.reconfigure(encoding='utf-8') if hasattr(sys.stdout, 'reconfigure') else None
    
    root = tk.Tk()
    app = DJIPlayerGUI(root)
    
    def on_closing():
        if app.is_exporting:
            if not messagebox.askyesno("Exporting Active", "An export is still in progress. Do you really want to exit?"):
                return
            if app.export_proc:
                try: app.export_proc.kill()
                except: pass
        if app.playback_proc:
            try: app.playback_proc.kill()
            except: pass
        root.destroy()

    root.protocol("WM_DELETE_WINDOW", on_closing)
    root.mainloop()
